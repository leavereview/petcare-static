    values: [true, true, false]
  },
  {
    label: 'Mobile-Responsive Access',
    values: [true, false, false]
  },
  {
    label: 'Multi-location Support',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Monthly Cost',
