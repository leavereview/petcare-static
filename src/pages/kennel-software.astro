---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbsEnhanced from '../components/seo/BreadcrumbsEnhanced.astro';
import FeaturedAnswer from '../components/seo/FeaturedAnswer.astro';
import StatisticsSection from '../components/seo/StatisticsSection.astro';
import ComparisonTable from '../components/seo/ComparisonTable.astro';
import FAQEnhanced from '../components/seo/FAQEnhanced.astro';

// Breadcrumb data
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Kennel Software' }
];

// Kennel industry statistics
// Sources: PFMA Pet Population Report 2024; Local Government Association (LGA) licensing data;
// CFSG Pet Industry Census 2024; UK Pet Boarding Digital Adoption Survey 2024
const kennelStats = [
  {
    label: 'UK Licensed Boarding Kennels',
    value: '3,500+',
    change: { value: 18, direction: 'up' as const, period: 'since 2020' },
    context: 'Source: CFSG Pet Industry Census 2024 (licensed facilities, estimated)'
  },
  {
    label: 'Annual Average Occupancy',
    value: '74–80%',
    context: 'Across surveyed UK kennels; peaks at 95%+ during school holidays'
  },
  {
    label: 'Kennels Using Management Software',
    value: '48%',
    change: { value: 35, direction: 'up' as const, period: 'since 2021' },
    context: 'Source: UK Pet Boarding Digital Adoption Survey 2024'
  },
  {
    label: 'Time Saved vs Manual Methods',
    value: '12–15 hrs/wk',
    context: 'Self-reported by kennel operators after switching from paper/diary systems'
  },
  {
    label: 'PFMA: UK Pet Population',
    value: '36M pets',
    context: 'Source: PFMA Pet Population Report 2024 (includes dogs, cats, small pets)'
  },
  {
    label: 'Local Authority Inspections',
    value: 'Annual',
    context: 'UK Animal Activity Licensing requires annual licence renewal and inspection readiness'
  }
];

// Feature comparison table
const comparisonData = [
  {
    label: 'Online Booking 24/7',
    values: [true, true, false],
    highlight: true
  },
  {
    label: 'Kennel Run Assignment System',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Vaccination Tracking with Alerts',
    values: [true, false, false]
  },
  {
    label: 'Digital Feeding Schedule Logs',
    values: [true, false, false]
  },
  {
    label: 'Medication Administration Records',
    values: [true, false, false]
  },
  {
    label: 'Staff Task Lists (Daily Care)',
    values: [true, false, false]
  },
  {
    label: 'Automated Deposit Collection',
    values: [true, true, false],
    highlight: true
  },
  {
    label: 'Owner Portal with Photo Updates',
    values: [true, false, false]
  },
  {
    label: 'Multi-Species (Dogs + Cats)',
    values: [true, false, false]
  },
  {
    label: 'Monthly Cost',
    values: ['From £79', 'From £80', 'Manual/Free']
  }
];

// FAQ data
const faqItems = [
  {
    question: 'What is kennel software?',
    answer: 'Kennel software is a management platform designed for licensed pet boarding facilities. It handles online bookings, kennel run or room assignments, vaccination tracking with automatic expiry alerts, feeding and medication schedules, digital care logs, staff task management, automated payments and deposits, and owner communication with photo updates. Purpose-built systems save facilities 12–15 hours per week compared to paper diaries and spreadsheets, and produce the digital records that support local authority licence inspections.',
    links: [
      { text: 'Dog Boarding Software', url: '/dog-boarding-software/' },
      { text: 'Dog Daycare Software', url: '/dog-daycare-software/' }
    ]
  },
  {
    question: 'How much does kennel software cost?',
    answer: 'Kennel software typically costs £40–150 per month depending on facility size, features, and whether it includes staff scheduling and multi-location support. MyPetCare offers flat pricing from £79 per month with no per-booking transaction fees and all features included. Avoid platforms that charge a percentage per booking — at typical kennel volumes across a busy school holiday period, per-transaction fees add up to thousands annually.',
    links: [
      { text: 'View Pricing', url: '/pricing/' }
    ]
  },
  {
    question: 'Is kennel software worth it for a small facility?',
    answer: 'For most kennel operators, yes. Even a 15-run facility typically saves 10–15 hours per week on booking calls, vaccination checks, feeding sheet preparation, and invoicing. The time savings alone usually justify the cost within the first month. Beyond admin time, the operational improvements — no double-bookings, automated reminders, digital care records — have value that\'s harder to quantify but directly affects the quality of care you can provide.',
    links: [
      { text: 'See Early Access Pricing', url: '/early-access/' }
    ]
  },
  {
    question: 'Can kennel software help with local authority licence inspections?',
    answer: 'Yes. UK kennels operating under the Animal Activity Licensing (AAL) regulations require annual licence renewal, and inspectors assess record-keeping as part of the process. Digital vaccination records with timestamps, care logs showing feeding and medication completion, emergency contact records, and risk assessment documentation all contribute to an inspection-ready record set. MyPetCare\'s records are structured to make this information retrievable in a format inspectors can review.',
  },
  {
    question: 'Can it handle both dogs and cats?',
    answer: 'Yes. MyPetCare manages dogs and cats from one platform with species-specific vaccination tracking (dogs: Bordetella, DHPP; cats: FVRCP, FeLV/FIV), separate capacity management for dog and cat areas, and individual enclosure or run assignment for each species. For mixed-species facilities, a single customer profile can hold multiple pets of different species, and bookings across service types use the same billing and reporting tools.',
    links: [
      { text: 'Cattery Software', url: '/cattery-software/' }
    ]
  },
  {
    question: 'How does vaccination tracking work for kennels?',
    answer: 'Each pet profile stores vaccination records with exact expiry dates. The system automatically sends owners reminder emails 30 and 60 days before their pet\'s vaccines expire. If a certificate lapses and no update is uploaded, the system flags the pet\'s upcoming bookings and can be configured to block new reservations until the record is current. For kennels preparing for local authority inspection, the vaccination database provides a complete digital compliance record covering all current and recent boarders.',
  },
  {
    question: 'How do feeding and medication logs work?',
    answer: 'Feeding instructions and medication schedules are stored on each pet\'s profile — meal times, portion sizes, food type, any allergies, medication name, dosage, and timing. Staff see a daily care schedule showing all feeding and medication tasks in time order. Each completed task is marked off from a phone or tablet with a timestamp and staff identifier. The completed log is visible to owners in their portal and provides a verifiable record for all care tasks during a stay.',
  },
  {
    question: 'How does staff handover work with kennel software?',
    answer: 'Digital care records make handover faster and more reliable than verbal briefings or written notes. The incoming shift sees which dogs are checked in, which kennel runs they\'re in, any care notes flagged by the outgoing team, and which feeding and medication tasks remain for their shift. Nothing is lost in translation between staff members. This is particularly important for evening and weekend handovers when the primary manager may not be on site.',
  },
  {
    question: 'What happens during the peak Christmas period?',
    answer: 'The system handles Christmas the same way as any other period: kennel runs are bookable online until they fill, capacity rules prevent overbooking, and the waitlist captures demand after you\'re full. Deposits collected at booking reduce last-minute cancellations. Automated reminders reduce no-shows. Daily photo updates reduce anxious owner calls during what is typically the highest-call period of the year. The peak period becomes a logistics exercise the system handles, not a crisis you manage.',
  },
  {
    question: 'How long does setup take?',
    answer: 'Most facilities are fully operational within one to two days. Setup involves configuring your kennel runs and capacity rules, importing or entering existing customer and pet records, connecting Stripe for payment processing, and going live with the booking widget on your website. MyPetCare\'s onboarding team guides you through each step. The 14-day free trial gives you time to process real bookings before making a long-term commitment.',
  }
];
---

<BaseLayout
  title="Kennel Software for UK Boarding Facilities | MyPetCare"
  description="Digital management for licensed boarding kennels. Kennel run assignments, vaccination tracking, feeding logs, and licence inspection records. No double-bookings. From £79/month."
  image="/images/blog-kennel.jpg"
>
  <!-- Breadcrumbs with Schema -->
  <div class="bg-gray-100 py-3">
    <div class="container-custom">
      <BreadcrumbsEnhanced items={breadcrumbs} site="petcare" />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-kennel.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Built for UK Licensed Boarding Kennels</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Kennel Software That Handles the Operations, Not Just the Bookings</h1>
        <p class="text-xl text-gray-300 mb-8">
          Kennel run assignments, vaccination compliance, feeding logs, medication records, and staff task lists — all from one platform. Designed for the way UK boarding kennels actually operate.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="btn-primary text-lg px-8 py-4">Start Free Trial</a>
          <a href="/early-access/" class="btn-secondary text-lg px-8 py-4">Join Early Access</a>
        </div>
        <p class="text-sm text-gray-400 mt-3">No credit card required · Set up in under 2 days</p>
      </div>
    </div>
  </section>

  <!-- Featured Answer for Featured Snippet -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <FeaturedAnswer question="What is kennel software?">
          Kennel software is a management platform for licensed pet boarding facilities that handles online bookings, kennel run assignments, vaccination tracking, feeding schedules, medication logs, staff task management, deposits, and owner communication. Purpose-built systems save 12–15 hours per week and produce the digital records that support UK Animal Activity Licensing inspections.
        </FeaturedAnswer>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <StatisticsSection
          title="UK Boarding Kennel Industry Statistics 2025–2026"
          description="Key data on the UK kennel sector, licensing environment, and digital adoption"
          stats={kennelStats}
          layout="grid"
          source="PFMA Pet Population Report 2024; CFSG Pet Industry Census 2024; UK Pet Boarding Digital Adoption Survey 2024"
          datePublished="2026-01-01"
          site="petcare"
          pageUrl={Astro.url.href}
        />
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h2 class="text-xl font-bold text-brand-navy mb-4">In This Guide</h2>
          <ul class="grid md:grid-cols-2 gap-2 text-gray-700">
            <li><a href="#problem" class="hover:text-brand-red">→ Where Paper Systems Break Down</a></li>
            <li><a href="#what-is" class="hover:text-brand-red">→ What Kennel Software Does</a></li>
            <li><a href="#features" class="hover:text-brand-red">→ Key Features Explained</a></li>
            <li><a href="#comparison" class="hover:text-brand-red">→ Feature Comparison</a></li>
            <li><a href="#case-study" class="hover:text-brand-red">→ Case Study: Meadow View Kennels</a></li>
            <li><a href="#compliance" class="hover:text-brand-red">→ Licence Compliance and Records</a></li>
            <li><a href="#early-access" class="hover:text-brand-red">→ Early Access Programme</a></li>
            <li><a href="#faq" class="hover:text-brand-red">→ FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Narrative -->
  <section class="section bg-white" id="problem">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Where Paper and Diary Systems Break Down for Kennels</h2>

        <p class="text-lg text-gray-700 mb-6">
          Running a boarding kennel is a complex operational task that most systems — paper diaries, spreadsheets, WhatsApp groups — were never designed for. The work involves managing dozens of individual animals simultaneously, each with their own care requirements, vaccination status, feeding schedule, and owner communication needs. When it works, it's because of experience and attentiveness. When it fails, it fails in ways that are hard to recover from.
        </p>

        <p class="text-gray-700 mb-6">
          The specific failure modes are predictable. Bookings taken by phone don't always make it onto the diary before the same slot is offered to the next caller. Vaccination certificates are filed in physical folders that the morning staff member has to manually check before every check-in. The feeding sheet for Run 7 is in the handwriting of the staff member who did the previous shift, and at 6pm on a Saturday, nobody can quite read whether that's 200g or 300g. A dog on medication needs to be given a tablet at 8am but the note is on a Post-it that transferred to someone's jacket pocket.
        </p>

        <p class="text-gray-700 mb-6">
          These aren't signs of a poorly run kennel — they're the predictable limits of paper-based operations under the pressures of a busy facility. Experienced kennel operators work around these limits every day. But working around them takes time, causes stress, and creates avoidable risk.
        </p>

        <div class="bg-red-50 border-l-4 border-brand-red p-6 my-8 rounded">
          <p class="font-bold text-brand-navy mb-2">The Animal Activity Licensing Factor</p>
          <p class="text-gray-700">UK boarding kennels must hold a current Animal Activity Licence and be subject to annual inspection by the local authority. Inspectors assess not just the physical facility but the quality of record-keeping: vaccination compliance records, care logs, emergency contact information, and risk assessment documentation. Paper systems rarely produce the kind of clean, retrievable record set that impresses an inspector. Digital systems can.</p>
        </div>

        <p class="text-gray-700 mb-6">
          Staff handover is another area where paper systems reach their limits. A morning shift briefing that relies on verbal communication or a handwritten note in a logbook is vulnerable to gaps — things that were known by the outgoing shift but didn't make it to the incoming one. Medication missed. A dog that was off its food flagged to one person but not the next. A behavioural note that gets lost.
        </p>

        <div class="grid md:grid-cols-2 gap-4 my-8">
          <div class="flex items-start gap-3 bg-gray-50 p-4 rounded-lg">
            <span class="text-brand-red text-2xl font-bold leading-none">✗</span>
            <div>
              <p class="font-semibold text-brand-navy text-sm">Before: Paper diary + feeding sheets</p>
              <p class="text-gray-600 text-sm mt-1">Booking conflicts at peak times, vaccine checks take 30 min/morning, handover relies on verbal briefing, inspection prep a scramble</p>
            </div>
          </div>
          <div class="flex items-start gap-3 bg-green-50 p-4 rounded-lg border border-green-200">
            <span class="text-green-600 text-2xl font-bold leading-none">✓</span>
            <div>
              <p class="font-semibold text-brand-navy text-sm">After: MyPetCare</p>
              <p class="text-gray-600 text-sm mt-1">No booking conflicts, vaccine status in one click, digital handover logs, inspection-ready records always current</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is Section -->
  <section class="section bg-gray-50" id="what-is">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">What Kennel Management Software Actually Does</h2>
        <p class="text-lg text-gray-700 mb-6">
          <strong>Kennel software</strong> is a digital management platform built around the specific operational requirements of licensed pet boarding facilities. It's different from a general appointment booking system in that it manages individual named spaces (runs, kennels, rooms), tracks care records against those spaces and the animals in them, coordinates staff workflows, and maintains the documentation that boarding kennels need for compliance.
        </p>
        <p class="text-gray-700 mb-6">
          In practice, a kennel management platform handles the full lifecycle of a boarding stay: online booking and deposit collection, kennel run assignment, vaccination verification at check-in, daily feeding and medication task lists for staff, photo updates to owners, and automated invoicing at check-out. Each step that previously required a manual action — a phone call, a diary entry, a form, a certificate check — becomes a system-managed process.
        </p>
        <p class="text-gray-700 mb-6">
          MyPetCare supports both dog boarding and <a href="/cattery-software/" class="text-brand-red hover:underline">cat boarding</a> from the same platform, with species-specific vaccination tracking, separate capacity management for dog and cat areas, and unified reporting across all services. If you also run <a href="/dog-daycare-software/" class="text-brand-red hover:underline">dog daycare</a>, the same customer profiles and billing tools cover all service types without duplication.
        </p>

        <figure class="screenshot">
          <img
            src="/images/screenshots/calendar-report.png"
            alt="Kennel booking calendar showing room assignments, booking IDs and status across the month"
            width="1200"
            height="675"
            loading="lazy"
          />
          <figcaption>Kennel calendar — every room, every booking, every status visible in one view</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section bg-white" id="features">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Key Features for Boarding Kennels</h2>
        <p class="text-gray-600 mb-10">The features below address the specific operational problems that matter most for licensed boarding kennels in the UK.</p>

        <!-- Feature 1 -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">1. Kennel Run Assignment and Capacity Management</h3>
          <p class="text-gray-700 mb-4">
            Each kennel run or room in your facility is configured as a named unit in the system with a size designation, species assignment (dogs only, cats only, or mixed), and any special designations (quiet area, accessible run, large breed run). When a booking is confirmed, you assign a specific run or use auto-assignment based on the pet's size and your rules. The system shows a grid of all runs with their current status in real time.
          </p>
          <p class="text-gray-700 mb-4">
            Capacity management operates at the run level — not just a total count. When every run of a given size is booked for a date range, those options disappear from the booking flow. Holiday periods, when demand peaks and the risk of overbooking is highest, are managed by the same rules as quieter periods without any manual intervention or special calendar management.
          </p>
          <p class="text-gray-700 mb-6">
            Blocking runs for deep cleaning, maintenance, or inspection preparation is a single action that prevents bookings being accepted for that period. Related: <a href="/blog/kennel-software-complete-guide/" class="text-brand-red hover:underline">Kennel Software: The Complete Guide for UK Facilities</a>.
          </p>
          <figure class="screenshot">
            <img
              src="/images/screenshots/vacinnation-tracker-report.png"
              alt="Vaccination tracker dashboard showing expired, expiring soon and compliant pets with contact tools"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Vaccination tracker flags expired and expiring records — contact owners directly from the dashboard</figcaption>
          </figure>
        </div>

        <!-- Feature 2 -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">2. Vaccination Tracking and Compliance Records</h3>
          <p class="text-gray-700 mb-4">
            Vaccination compliance is a legal and welfare requirement for licensed boarding kennels. The manual alternative — physically checking paper certificates against a list every morning — takes 20–30 minutes per day and creates gaps when certificates have been filed incorrectly or the morning check is rushed during a busy arrival period.
          </p>
          <p class="text-gray-700 mb-4">
            The vaccination tracker stores each pet's certificates with exact expiry dates. Owners receive automatic reminder emails 30 and 60 days before vaccines expire, giving them time to book their vet without urgency. If a certificate lapses, the system flags the pet and can block new bookings until an updated certificate is uploaded. Dogs are tracked for core vaccines (Bordetella, DHPP, Leptospirosis); cats for FVRCP and FeLV/FIV testing.
          </p>
          <p class="text-gray-700 mb-6">
            For local authority inspections, the full vaccination database — every pet boarded, vaccination status, certificate dates — is retrievable as a report. This turns inspection preparation from a filing exercise into a system export. See also: <a href="/blog/vaccination-tracking-for-kennels/" class="text-brand-red hover:underline">Vaccination Tracking for Kennels: A Compliance Guide</a>.
          </p>
          <figure class="screenshot">
            <img
              src="/images/screenshots/occupancy-report.png"
              alt="Kennel occupancy report showing capacity percentage by day with calendar heatmap"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Occupancy report with heatmap — spot your busiest periods and manage capacity proactively</figcaption>
          </figure>
          <figure class="screenshot">
            <img
              src="/images/screenshots/arrivals-depatures-report.png"
              alt="Arrivals and departures report showing upcoming check-ins with payment and vaccine alerts"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Arrivals report surfaces payment and vaccination issues before the dog arrives</figcaption>
          </figure>
        </div>

        <!-- Feature 3 -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">3. Digital Care Logs and Staff Task Lists</h3>
          <p class="text-gray-700 mb-4">
            The daily care log replaces paper feeding sheets, medication records, and handover notes with a digital task list that all staff access from their phone or tablet. Each pet's profile holds their feeding instructions, medication schedule, and any behavioural or health notes. These generate a daily task list for staff showing every care action required that day in time order.
          </p>
          <p class="text-gray-700 mb-4">
            Staff mark tasks as completed with a tap, and each completion is logged with a timestamp and their name. This creates a full audit trail of care delivered during every stay — useful for owner queries, veterinary consultations, and inspection records. Any issue flagged during a task (a dog refusing food, a cat appearing lethargic) is logged as a note visible to all staff and, optionally, to owners.
          </p>
          <p class="text-gray-700 mb-6">
            Handover between shifts is straightforward: the incoming team opens the app and sees every animal currently boarded, their run, outstanding care tasks for the shift, and any notes flagged by the previous team. Nothing is lost in translation. The 20-minute verbal briefing becomes a five-minute digital check.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">4. Online Booking, Deposits, and Owner Communication</h3>
          <p class="text-gray-700 mb-4">
            The booking widget embeds on your website or links from your Google Business Profile. Owners select arrival and departure dates, choose a run type based on their dog's size, add any services or special requests, and pay a deposit — all without calling your facility. The booking confirmation goes out automatically with check-in instructions and your vaccination requirements.
          </p>
          <p class="text-gray-700 mb-4">
            Deposits collected at booking reduce no-shows and last-minute cancellations — particularly important over Christmas and bank holidays when replacing a cancelled booking is very difficult. Your deposit policy and cancellation terms are applied consistently by the system regardless of which staff member handles a particular enquiry.
          </p>
          <p class="text-gray-700 mb-6">
            During a stay, staff send owners daily photo updates from their phone with a brief care note. Owners see feeding logs, medication records, and general notes in their portal without calling. This is the single most effective way to reduce the volume of "how is my dog?" calls that interrupt kennel operations during peak periods.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Calculator CTA -->
  <section class="section bg-white">
    <div class="container-custom max-w-4xl">
      <div class="bg-gray-50 border-l-4 border-brand-red p-6 rounded-lg my-8">
        <h3 class="text-xl font-bold text-brand-navy mb-2">Model Your Kennel Revenue and Time Savings</h3>
        <p class="text-gray-600 mb-4">
          Use our free Revenue Calculator to model your kennel income, occupancy across seasons, and the admin hours you'd recover by switching from paper to digital.
        </p>
        <a href="/pet-business-calculator/" class="text-brand-red font-medium hover:underline inline-flex items-center gap-2">
          Try the Calculator
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section bg-gray-50" id="comparison">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <ComparisonTable
          title="Kennel Software Feature Comparison"
          description="MyPetCare vs generic booking tools vs paper and spreadsheet management"
          headers={['Feature', 'MyPetCare', 'Generic Pet Software', 'Manual/Spreadsheets']}
          rows={comparisonData}
          sortable={true}
        />
      </div>
    </div>
  </section>

  <!-- Case Study -->
  <section class="section bg-white" id="case-study">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <span class="inline-block bg-brand-red/10 text-brand-red px-3 py-1 rounded-full text-sm mb-4 font-medium">Case Study</span>
        <h2 class="text-3xl font-bold text-brand-navy mb-2">How Meadow View Kennels Turned a Failed Inspection Into a Compliance Strength</h2>
        <p class="text-gray-500 mb-8 text-sm">Chester boarding kennel · 30 runs · switched from paper diary + filing cabinet records</p>

        <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 mb-8">
          <div class="grid md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
              <p class="text-3xl font-bold text-brand-red">Passed</p>
              <p class="text-sm text-gray-600 mt-1">Next inspection — first time with no conditions</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-brand-red">−3 hrs</p>
              <p class="text-sm text-gray-600 mt-1">Daily admin time saved</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-brand-red">5 min</p>
              <p class="text-sm text-gray-600 mt-1">Shift handover (was 25 minutes)</p>
            </div>
          </div>

          <h3 class="text-xl font-bold text-brand-navy mb-3">The Problem</h3>
          <p class="text-gray-700 mb-4">
            Rachel and Pete Simmons have run Meadow View Kennels in Chester for nine years with 30 kennel runs and a recent expansion into cat boarding with six individual enclosures. Their operations were managed with a booking diary, a paper vaccination certificate folder, and handwritten feeding sheets that staff exchanged at shift changeover.
          </p>
          <p class="text-gray-700 mb-6">
            The system worked until an annual local authority inspection in 2024 flagged two issues: three pets had been boarded whose vaccination records could not be immediately produced, and the feeding records for one dog with a complex medication schedule were incomplete for two days of a recent stay. The kennel received a conditional licence renewal with specific requirements for improved record-keeping. Rachel described the experience as "humiliating — we were doing everything right in terms of the actual care, but we couldn't prove it on paper."
          </p>

          <h3 class="text-xl font-bold text-brand-navy mb-3">The Switch</h3>
          <p class="text-gray-700 mb-6">
            The Simmons joined MyPetCare's early access programme and spent two weekends importing all existing customer and pet records into the system. Vaccination certificates were scanned and uploaded against each profile. Kennel runs were configured in the booking system. By the third week, all new bookings were coming in online and the paper feeding sheets had been retired in favour of staff task lists on phones.
          </p>
          <p class="text-gray-700 mb-6">
            The most immediate operational improvement was handover. The incoming shift had previously spent 20–25 minutes going through the paper logbook and diary with the outgoing team. With digital care logs and the kennel run overview visible on any device, the same handover now takes around five minutes: a quick review of the board, any flagged notes, and the day's arrivals and departures.
          </p>

          <h3 class="text-xl font-bold text-brand-navy mb-3">The Results</h3>
          <p class="text-gray-700 mb-4">
            When the local authority inspection came around the following year, Rachel exported the vaccination compliance report and the care log summary for the previous six months and had them ready on a tablet for the inspector. All records were complete, timestamped, and retrievable without searching through filing cabinets. The facility passed with no conditions for the first time.
          </p>
          <p class="text-gray-700">
            Daily admin time dropped from around four hours to just under one hour. The vaccination check at the start of each day — previously a manual scan through the certificate folder — is now a one-click dashboard view. "We spend so much less time on paperwork that we've been able to take on two more dogs each day," Pete said. "The capacity was always there. The admin was the bottleneck."
          </p>
        </div>

        <p class="text-sm text-gray-400 italic">* This case study is based on typical outcomes reported by early access customers and composites several similar facilities. Individual results vary.</p>
      </div>
    </div>
  </section>

  <!-- Compliance Section -->
  <section class="section bg-gray-50" id="compliance">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Kennel Software and Animal Activity Licensing Compliance</h2>

        <p class="text-gray-700 mb-6">
          UK boarding kennels operating under the Animal Activity Licensing (AAL) regulations must hold a current licence and are subject to annual inspections by the local authority. Inspectors assess both the physical standards of the facility and the quality of its record-keeping and management systems. Facilities rated at four or five stars — the highest rating — are eligible for a three-year licence instead of the annual renewal.
        </p>

        <p class="text-gray-700 mb-6">
          Good record-keeping is explicitly assessed as part of the inspection process. Inspectors look for: vaccination compliance records for all boarded animals, care logs showing feeding and medication delivery, emergency contact information for all current boarders, risk assessment documentation, and staff training records. These records need to be current, retrievable, and legible.
        </p>

        <div class="grid md:grid-cols-2 gap-4 my-8">
          <div class="bg-white p-5 rounded-lg border border-gray-200">
            <h4 class="font-bold text-brand-navy mb-2 text-sm">What Inspectors Look For</h4>
            <ul class="text-gray-600 text-sm space-y-1">
              <li>→ Vaccination records for all current boarders</li>
              <li>→ Complete feeding and medication logs</li>
              <li>→ Emergency contact details for each pet</li>
              <li>→ Evidence of staff training and procedures</li>
              <li>→ Incident and health records where applicable</li>
            </ul>
          </div>
          <div class="bg-white p-5 rounded-lg border border-gray-200">
            <h4 class="font-bold text-brand-navy mb-2 text-sm">What MyPetCare Provides</h4>
            <ul class="text-gray-600 text-sm space-y-1">
              <li>→ Vaccination database with certificate uploads and expiry dates</li>
              <li>→ Timestamped feeding and medication completion logs</li>
              <li>→ Owner and emergency contact details on each profile</li>
              <li>→ Care notes and incident flags on each stay record</li>
              <li>→ Exportable compliance reports for inspection</li>
            </ul>
          </div>
        </div>

