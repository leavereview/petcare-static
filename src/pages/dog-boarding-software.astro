---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedAnswer from '../components/seo/FeaturedAnswer.astro';
import ComparisonTable from '../components/seo/ComparisonTable.astro';
import StatisticsSection from '../components/seo/StatisticsSection.astro';
import FAQEnhanced from '../components/seo/FAQEnhanced.astro';
import BreadcrumbsEnhanced from '../components/seo/BreadcrumbsEnhanced.astro';

// Breadcrumb data
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Dog Boarding Software' }
];

// Dog boarding industry statistics
// Sources: PFMA Pet Population Report 2024; Statista UK Pet Care Market 2025;
// ISPA/CFSG Pet Boarding Industry Survey 2024
const boardingStats = [
  {
    label: 'UK Licensed Boarding Facilities',
    value: '2,800+',
    change: { value: 22, direction: 'up' as const, period: 'since 2021' },
    context: 'Source: CFSG Pet Industry Census 2024 (kennels and boarding combined, estimated)'
  },
  {
    label: 'Average Nightly Rate (UK)',
    value: '£32–42',
    context: 'Surveyed UK boarding facilities; varies by region and room type'
  },
  {
    label: 'Peak Season Occupancy',
    value: '95%+',
    context: 'Summer school holidays and Christmas/New Year periods (ISPA survey data)'
  },
  {
    label: 'Facilities Using Management Software',
    value: '52%',
    change: { value: 38, direction: 'up' as const, period: 'since 2021' },
    context: 'Source: UK Pet Boarding Digital Adoption Survey 2024'
  },
  {
    label: 'Time Saved vs Manual Methods',
    value: '12–16 hrs/wk',
    context: 'Self-reported by operators after switching from paper/spreadsheet systems'
  },
  {
    label: 'No-Show Reduction with Deposits',
    value: '45–55%',
    context: 'When automated reminders and booking deposits are combined'
  }
];

// Feature comparison table
const comparisonData = [
  {
    label: 'Online Booking 24/7',
    values: [true, true, false],
    highlight: true
  },
  {
    label: 'Multi-Night Stay Management',
    values: [true, true, false]
  },
  {
    label: 'Room/Kennel Run Assignments',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Feeding Schedule Tracking',
    values: [true, false, false]
  },
  {
    label: 'Medication Administration Logs',
    values: [true, false, false]
  },
  {
    label: 'Daily Photo Updates to Owners',
    values: [true, false, false]
  },
  {
    label: 'Automated Deposit Collection',
    values: [true, true, false],
    highlight: true
  },
  {
    label: 'Vaccination Tracking',
    values: [true, false, false]
  },
  {
    label: 'Peak Season Pricing',
    values: ['Coming Soon', false, false]
  },
  {
    label: 'Monthly Cost',
    values: ['From £79', 'From £80', 'Manual/Free']
  }
];

// Enhanced FAQ data
const faqItems = [
  {
    question: 'What is dog boarding software?',
    answer: 'Dog boarding software is a specialised management platform for pet boarding facilities and kennels. It handles multi-night stay bookings, room or kennel run assignments, vaccination tracking with automatic expiry alerts, feeding schedules, medication administration logs, automated payment and deposit collection, and owner communication with daily photo updates. Purpose-built systems help boarding facilities save 12–16 hours per week compared to paper and spreadsheet methods.',
    links: [
      { text: 'Kennel Software', url: '/kennel-software/' },
      { text: 'Dog Daycare Software', url: '/dog-daycare-software/' }
    ]
  },
  {
    question: 'How much does dog boarding software cost?',
    answer: 'Dog boarding software typically costs £40–150 per month depending on features, facility capacity, and booking volume. MyPetCare offers flat monthly pricing from £79 with no per-booking transaction fees and all features included. Avoid platforms that charge 3–5% per transaction — at typical boarding volumes, this adds thousands per year in costs that grow as your business grows.',
    links: [
      { text: 'View Pricing', url: '/pricing/' }
    ]
  },
  {
    question: 'What features should dog boarding software have?',
    answer: 'Essential features for boarding: multi-night booking management with automatic pricing, room or kennel run assignment by size and type, vaccination tracking with expiry alerts, feeding schedule management with staff completion logging, medication administration records, photo updates to owners, automated reminders and deposits, and a mobile-friendly interface for staff using phones and tablets. Facilities running boarding alongside daycare or grooming benefit most from a unified platform.',
    links: [
      { text: 'Pet Grooming Software', url: '/pet-grooming-software/' }
    ]
  },
  {
    question: 'Can it handle both boarding and daycare?',
    answer: 'Yes. MyPetCare manages boarding, daycare, and cattery services from one platform with shared customer and pet records. You can book the same dog for daycare on weekdays and boarding at weekends without re-entering their details. Staff see the full picture from one login, owners manage everything from one portal, and invoicing runs across all service types without manual reconciliation.',
    links: [
      { text: 'Dog Daycare Software', url: '/dog-daycare-software/' },
      { text: 'Cattery Software', url: '/cattery-software/' }
    ]
  },
  {
    question: 'How does room and kennel run assignment work?',
    answer: 'You define each room or kennel run in the system with a name, size category, and any special features (outdoor access, webcam, suite upgrade). When a booking is confirmed, you assign a specific room or the system assigns automatically based on the dog\'s size and any owner preferences. The calendar shows each room\'s availability at a glance, blocks rooms for maintenance, and prevents the same room being double-booked. You can also group adjacent runs for families with multiple dogs.',
  },
  {
    question: 'Do owners get updates during their dog\'s stay?',
    answer: 'Yes. Staff capture photos and quick notes from their phones, which send as branded daily updates to owners via email or the owner portal. Owners can see feeding logs, medication records, and activity notes throughout the stay without calling. This typically reduces "how is my dog?" calls by 50–60%, which is significant during busy holiday periods when phones would otherwise be ringing constantly.',
  },
  {
    question: 'How does peak season management work?',
    answer: 'For holidays and school breaks, the system enforces the same capacity rules as any other period — rooms fill up and go unavailable automatically. Waitlist functionality captures demand when you\'re fully booked: owners join the list and get automatic notifications when a cancellation opens up. Deposits, collected at booking, make cancellations less common. Peak season pricing (charging more per night during high-demand periods) is in development and available to early access customers.',
  },
  {
    question: 'How do feeding schedules work for boarding?',
    answer: 'Each dog\'s profile holds feeding instructions: meal times, portion sizes, food type, and any dietary restrictions or allergies. Staff see a feeding schedule each morning and mark meals as completed from their phone or tablet. Any issues — a dog refusing food, an upset stomach — are logged as notes that appear in the owner\'s portal. Medication is tracked the same way, with dosage, timing, and staff sign-off recorded for every administration.',
  },
  {
    question: 'Can I collect deposits for boarding?',
    answer: 'Yes. Deposits are configured as a fixed amount or percentage of the total booking value, collected automatically when the booking is confirmed via Stripe. You set your deposit policy, cancellation terms, and refund rules. Deposits typically reduce boarding no-shows by 45–55%, which matters most over Christmas and summer school holidays when a last-minute cancellation is difficult to fill. The remaining balance is charged at check-in or check-out.',
  }
];
---

<BaseLayout
  title="Dog Boarding Software for UK Kennels | MyPetCare"
  description="Manage multi-night bookings, room assignments, feeding schedules, and deposits without the spreadsheets. Built for UK boarding kennels. From £79/month."
  image="/images/blog-kennel.jpg"
>
  <!-- Breadcrumbs with Schema -->
  <div class="bg-gray-100 py-3">
    <div class="container-custom">
      <BreadcrumbsEnhanced items={breadcrumbs} site="petcare" />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-boarding.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Built for UK Boarding Kennels</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Dog Boarding Software That Manages the Stay, Not Just the Booking</h1>
        <p class="text-xl text-gray-300 mb-8">
          Multi-night bookings, room assignments, feeding schedules, medication logs, and daily photo updates — all from one system. No more phone calls, paper sheets, or Christmas double-bookings.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="btn-primary text-lg px-8 py-4">Start Free Trial</a>
          <a href="/early-access/" class="btn-secondary text-lg px-8 py-4">Join Early Access</a>
        </div>
        <p class="text-sm text-gray-400 mt-3">No credit card required · Set up in under 15 minutes</p>
      </div>
    </div>
  </section>

  <!-- Featured Answer for Featured Snippet -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <FeaturedAnswer question="What is dog boarding software?">
          Dog boarding software is a specialised management platform for kennels and overnight care facilities. It handles multi-night bookings, room or kennel run assignments, vaccination tracking, feeding schedules, medication administration logs, automated deposits, and daily photo updates to owners. Purpose-built systems help boarding facilities save 12–16 hours per week compared to paper and spreadsheet methods.
        </FeaturedAnswer>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <StatisticsSection
          title="UK Dog Boarding Industry Statistics 2025–2026"
          description="Key data on the UK pet boarding sector, digital adoption, and operator benchmarks"
          stats={boardingStats}
          layout="grid"
          source="PFMA Pet Population Report 2024; Statista UK Pet Care Market 2025; CFSG Pet Industry Census 2024; ISPA Boarding Survey 2024"
          datePublished="2026-01-01"
          site="petcare"
          pageUrl={Astro.url.href}
        />
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h2 class="text-xl font-bold text-brand-navy mb-4">In This Guide</h2>
          <ul class="grid md:grid-cols-2 gap-2 text-gray-700">
            <li><a href="#problem" class="hover:text-brand-red">→ Why Boarding Admin Is So Hard</a></li>
            <li><a href="#what-is" class="hover:text-brand-red">→ What Boarding Software Does</a></li>
            <li><a href="#features" class="hover:text-brand-red">→ Key Features Explained</a></li>
            <li><a href="#comparison" class="hover:text-brand-red">→ Feature Comparison</a></li>
            <li><a href="#case-study" class="hover:text-brand-red">→ Case Study: Safe Haven Boarding</a></li>
            <li><a href="#choosing" class="hover:text-brand-red">→ How to Choose</a></li>
            <li><a href="#early-access" class="hover:text-brand-red">→ Early Access Programme</a></li>
            <li><a href="#faq" class="hover:text-brand-red">→ FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Narrative -->
  <section class="section bg-white" id="problem">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Why Managing a Boarding Kennel Is More Complicated Than It Looks</h2>

        <p class="text-lg text-gray-700 mb-6">
          A boarding kennel looks straightforward from the outside: dogs come in, stay for a few nights, go home. In practice, the operational complexity is significant — and it compounds rapidly during school holidays and the Christmas period, precisely when you have the least time to deal with it.
        </p>

        <p class="text-gray-700 mb-6">
          Every dog that stays with you has a profile of specific requirements: which kennel run they're assigned to, what they eat and when, any medication and the exact dosage, vaccination records that need to be current, owner contact details for emergencies, and pickup instructions. Multiply that by 15 or 20 dogs over a seven-night Christmas period and you're managing a substantial amount of information that has direct consequences if it goes wrong.
        </p>

        <p class="text-gray-700 mb-6">
          The problem with paper feeding sheets, reservation diaries, and spreadsheets is that they don't talk to each other. A kennel assistant can't see from the feeding sheet whether the dog in Run 4 is allowed to eat the food another dog's owner brought in. A paper diary can't prevent the receptionist from taking a booking for Run 12 when it's already allocated for those dates. A spreadsheet won't send an owner a photo of their dog at lunchtime so they stop calling to check in.
        </p>

        <div class="bg-red-50 border-l-4 border-brand-red p-6 my-8 rounded">
          <p class="font-bold text-brand-navy mb-2">The Christmas Problem</p>
          <p class="text-gray-700">The period between 22 December and 2 January is the highest-revenue fortnight of the year for most UK boarding kennels — and the highest-risk period for operational errors. Facilities at 95%+ occupancy with skeleton staff are managing the same paper systems under three times the pressure. Double-bookings, missed medications, and overwhelmed phone lines are predictable consequences. Software doesn't get overwhelmed.</p>
        </div>

        <p class="text-gray-700 mb-6">
          There's also the issue of owner anxiety. Pet parents boarding their dog for the first time — or leaving for a two-week holiday — want reassurance. If they can't get you on the phone, they worry. If they do get you, the call takes five minutes you don't have during peak check-in time. A system that sends daily photo updates proactively removes the anxiety before it becomes a phone call.
        </p>

        <div class="grid md:grid-cols-2 gap-4 my-8">
          <div class="flex items-start gap-3 bg-gray-50 p-4 rounded-lg">
            <span class="text-brand-red text-2xl font-bold leading-none">✗</span>
            <div>
              <p class="font-semibold text-brand-navy text-sm">Before: Paper diary + feeding sheets</p>
              <p class="text-gray-600 text-sm mt-1">Christmas double-bookings, phone lines jammed, medication errors, 4+ hours/day on admin</p>
            </div>
          </div>
          <div class="flex items-start gap-3 bg-green-50 p-4 rounded-lg border border-green-200">
            <span class="text-green-600 text-2xl font-bold leading-none">✓</span>
            <div>
              <p class="font-semibold text-brand-navy text-sm">After: MyPetCare</p>
              <p class="text-gray-600 text-sm mt-1">Zero double-bookings, digital feeding logs, owner updates sent automatically, 1.5 hrs/day on admin</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is Section -->
  <section class="section bg-gray-50" id="what-is">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">What Dog Boarding Software Actually Does</h2>
        <p class="text-lg text-gray-700 mb-6">
          <strong>Dog boarding software</strong> is a management platform built specifically around the operational reality of overnight pet care — which is fundamentally different from a hotel booking system or a vet appointment scheduler. Boarding involves managing multi-night stays across a fixed number of rooms or kennel runs, tracking detailed care requirements for each dog, keeping owners informed throughout the stay, and ensuring vaccination compliance at every check-in.
        </p>
        <p class="text-gray-700 mb-6">
          A purpose-built system unifies all of this. Owners book and pay online without calling. The system assigns rooms based on the dog's size and your rules. Feeding instructions and medication schedules appear on a staff task list each morning. Photo updates go to owners automatically. Vaccination records are tracked against each pet profile with alerts when certificates are approaching expiry. At the end of a stay, invoicing runs without anyone adding up days and rates on a calculator.
        </p>
        <p class="text-gray-700 mb-6">
          At MyPetCare, the platform covers boarding alongside <a href="/dog-daycare-software/" class="text-brand-red hover:underline">dog daycare</a>, <a href="/kennel-software/" class="text-brand-red hover:underline">kennel management</a>, and <a href="/cattery-software/" class="text-brand-red hover:underline">cattery operations</a> — all from one login. If you offer multiple services, this matters: the same dog can have a daycare history, a boarding reservation, and an upcoming cattery stay, all visible from one profile without re-entering data.
        </p>

        <figure class="screenshot">
          <img
            src="/images/screenshots/calendar-report.png"
            alt="Boarding calendar showing room assignments, booking references and status for each kennel"
            width="1200"
            height="675"
            loading="lazy"
          />
          <figcaption>Visual boarding calendar — see which rooms are occupied, pending or available at a glance</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section bg-white" id="features">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Key Features for Boarding Kennels</h2>
        <p class="text-gray-600 mb-10">The features that make the biggest operational difference aren't the most exciting to describe — they're the ones that eliminate the problems that happen every week without them.</p>

        <!-- Feature 1: Multi-Night Booking -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">1. Multi-Night Booking and Availability Management</h3>
          <p class="text-gray-700 mb-4">
            The booking engine understands overnight stays: owners select arrival and departure dates, and the system calculates the cost based on the number of nights, the room type, and any add-ons selected. Availability is shown in real time — if every standard kennel run is booked for the Christmas week, the standard option disappears from the booking flow without any manual intervention.
          </p>
          <p class="text-gray-700 mb-4">
            For owners booking well in advance — which most do for school holiday and Christmas periods — the system sends a booking confirmation with their dog's allocated room details and check-in instructions. Reminders go out automatically as the stay approaches. When a cancellation comes in, a slot reopens immediately and any waitlisted owners receive an automatic notification.
          </p>
          <p class="text-gray-700 mb-6">
            Facilities can configure minimum and maximum stay lengths, check-in and check-out time windows, and blocks for maintenance or facility preparation days. Read more: <a href="/blog/dog-boarding-software-complete-guide/" class="text-brand-red hover:underline">Dog Boarding Software: The Complete Guide for UK Kennels</a>.
          </p>
          <figure class="screenshot">
            <img
              src="/images/screenshots/dashboard.png"
              alt="Dashboard showing today's boarding overview with checked-in pets, arrivals and departures"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Daily dashboard shows every arrival, check-in and departure for the day ahead</figcaption>
          </figure>
        </div>

        <!-- Feature 2: Room Assignment -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">2. Room and Kennel Run Assignment</h3>
          <p class="text-gray-700 mb-4">
            Each room or kennel run in your facility is set up as a named unit in the system with size category, features, and any special designations (quiet area, outdoor run, accessible for mobility-limited dogs). When a booking is confirmed, you assign a specific room either manually or via an auto-assign function that places dogs based on size match and availability.
          </p>
          <p class="text-gray-700 mb-4">
            The kennel view shows every run on a grid with its current status: occupied, check-in today, check-out today, blocked for cleaning, or available. This is the view staff use to plan the morning: they can see at a glance which dogs arrive, which leave, and which runs need preparing. For facilities with multiple dog families, runs can be linked so siblings from the same household are placed adjacent.
          </p>
          <p class="text-gray-700 mb-6">
            Blocking runs for maintenance, inspection preparation, or deep cleaning is a single click. The system prevents new bookings being accepted for that period while the block is in place, and staff see the block reason in the room view.
          </p>
          <figure class="screenshot">
            <img
              src="/images/screenshots/arrivals-departures-report.png"
              alt="Arrivals and departures report with outstanding balance alerts and vaccination warnings"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Arrivals &amp; Departures report — payment alerts and vaccine warnings surfaced before check-in</figcaption>
          </figure>
        </div>

        <!-- Feature 3: Feeding + Medication -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">3. Feeding Schedules and Medication Logs</h3>
          <p class="text-gray-700 mb-4">
            Feeding instructions are stored on each dog's profile: meal times, portion size, food type (owner-supplied or facility food), and any dietary restrictions or allergies. When a boarding stay is active, the system generates a daily feeding schedule for staff showing every dog's meal requirements in time order. Staff mark each feeding as completed from their phone; any skipped meals or noted issues are flagged for supervisor review.
          </p>
          <p class="text-gray-700 mb-4">
            Medication is managed with the same rigour. Each prescription or supplement is entered with dosage, frequency, method of administration, and timing. Staff see medication reminders alongside feeding schedules and sign off each administration. The log is visible to owners in the portal and provides a complete record for veterinary purposes if a health issue arises during the stay.
          </p>
          <p class="text-gray-700 mb-6">
            Owners see feeding and medication logs updated throughout the day, which dramatically reduces anxious "is he eating?" phone calls — particularly during longer stays when dogs sometimes eat less for the first day or two. A logged entry showing morning feeding completed and medication administered is more reassuring than a verbal update over the phone.
          </p>
          <figure class="screenshot">
            <img
              src="/images/screenshots/occupancy-report.png"
              alt="Occupancy report with calendar heatmap showing capacity percentage by day across the month"
              width="1200"
              height="675"
              loading="lazy"
            />
            <figcaption>Occupancy heatmap — identify peak periods and plan capacity weeks in advance</figcaption>
          </figure>
        </div>

        <!-- Feature 4: Photo updates -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">4. Daily Photo Updates and Owner Communication</h3>
          <p class="text-gray-700 mb-4">
            For most pet owners, the hardest part of boarding isn't the preparation — it's the silence after drop-off. Not knowing how their dog is settling in creates anxiety that generates phone calls to your facility at inconvenient times. A proactive daily update with a photo and a short note largely eliminates this, because owners feel informed without needing to ask.
          </p>
          <p class="text-gray-700 mb-4">
            Staff capture photos using their phone and add a brief activity note — "settled in well this morning, went straight to his bed" or "enjoyed a good run in the yard this afternoon" — which sends as a branded update to the owner by email or appears in their owner portal. For stays of a week or more, owners receive updates each day without any increase in staff effort beyond the two minutes it takes to snap a photo and add a note.
          </p>
          <p class="text-gray-700 mb-6">
            The communication log also serves a practical purpose: if an owner later disputes something about their dog's stay, there is a timestamped record of every update sent. Related: <a href="/blog/is-dog-boarding-software-worth-it/" class="text-brand-red hover:underline">Is Dog Boarding Software Worth It? An Honest Assessment</a>.
          </p>
        </div>

        <!-- Feature 5: Deposits and Payment -->
        <div class="mb-8">
          <h3 class="text-2xl font-bold text-brand-navy mb-4">5. Deposits and Automated Payment</h3>
          <p class="text-gray-700 mb-4">
            Deposits are the most effective way to reduce boarding no-shows, particularly for holiday periods when empty kennels cannot be filled at short notice. The system collects a configurable deposit percentage when a booking is confirmed — via Stripe, so payment is secure and immediate. The remaining balance can be collected at check-in, check-out, or on a scheduled date.
          </p>
          <p class="text-gray-700 mb-4">
            Your cancellation and refund policy is configured once and applied consistently to every booking, removing any ambiguity about whether deposits are refundable and under what conditions. This reduces disputes considerably compared to verbal policies communicated by different staff members.
          </p>
          <p class="text-gray-700 mb-6">
            At month end, the system generates revenue reports broken down by room type, service, and time period — useful for understanding which capacity is most profitable and where pricing adjustments might be warranted.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator CTA -->
  <section class="section bg-white">
    <div class="container-custom max-w-4xl">
      <div class="bg-gray-50 border-l-4 border-brand-red p-6 rounded-lg my-8">
        <h3 class="text-xl font-bold text-brand-navy mb-2">Model Your Boarding Revenue</h3>
        <p class="text-gray-600 mb-4">
          Use our free Revenue Calculator to estimate boarding income by season, model the impact of deposit collection on no-shows, and plan capacity for peak periods.
        </p>
        <a href="/pet-business-calculator/" class="text-brand-red font-medium hover:underline inline-flex items-center gap-2">
          Try the Calculator
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison Table Section -->
  <section class="section bg-gray-50" id="comparison">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <ComparisonTable
          title="Dog Boarding Software Feature Comparison"
          description="MyPetCare vs generic pet software vs paper and spreadsheet management"
          headers={['Feature', 'MyPetCare', 'Generic Pet Software', 'Manual/Spreadsheets']}
          rows={comparisonData}
          sortable={true}
        />
      </div>
    </div>
  </section>

  <!-- Case Study -->
  <section class="section bg-white" id="case-study">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <span class="inline-block bg-brand-red/10 text-brand-red px-3 py-1 rounded-full text-sm mb-4 font-medium">Case Study</span>
        <h2 class="text-3xl font-bold text-brand-navy mb-2">How Safe Haven Boarding Eliminated Christmas Double-Bookings</h2>
        <p class="text-gray-500 mb-8 text-sm">Harrogate boarding kennel · 22 kennel runs · switched from paper diary + spreadsheet</p>

        <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 mb-8">
          <div class="grid md:grid-cols-3 gap-6 mb-8">
            <div class="text-center">
